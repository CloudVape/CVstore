# ============================================================
# CloudVape — API Server Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env — it is listed in .gitignore.
# ============================================================

# ── Database ────────────────────────────────────────────────
# PostgreSQL connection string (Replit provides this automatically)
DATABASE_URL=postgresql://user:password@localhost:5432/cloudvape

# ── Server ──────────────────────────────────────────────────
# Port the Express server listens on (Replit sets this automatically)
PORT=3000

# "development" | "production" | "test"
NODE_ENV=development

# Logging verbosity: "fatal" | "error" | "warn" | "info" | "debug" | "trace"
LOG_LEVEL=info

# ── Session ─────────────────────────────────────────────────
# Secret used to sign session cookies — use a long random string
SESSION_SECRET=replace-with-a-long-random-secret

# ── Clerk Authentication ─────────────────────────────────────
# Secret key from your Clerk dashboard (starts with sk_live_ or sk_test_)
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Email (Resend) ───────────────────────────────────────────
# API key from resend.com (starts with re_)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Webhook signing secret from the Resend dashboard (starts with whsec_)
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Verified sender addresses configured in your Resend domain
FROM_EMAIL_TRANSACTIONAL=CloudVape <support@cloudvape.store>
FROM_EMAIL_MARKETING=CloudVape <hello@cloudvape.store>

# ── Support (inbound email webhook) ─────────────────────────
# Shared secret for authenticating inbound-email webhook calls
SUPPORT_WEBHOOK_SECRET=replace-with-a-random-secret

# ── Site ─────────────────────────────────────────────────────
# Public-facing base URL (no trailing slash)
SITE_URL=https://cloudvape.store
