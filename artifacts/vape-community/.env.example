# ============================================================
# CloudVape — Frontend (Vite) Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env — it is listed in .gitignore.
# All variables MUST start with VITE_ to be exposed to the browser.
# ============================================================

# Clerk publishable key (safe to expose — starts with pk_live_ or pk_test_)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clerk Frontend API proxy URL — only needed in production when using a custom
# domain. Points to the /api/__clerk path on your API server so Clerk auth
# works without requiring CNAME DNS configuration.
# Leave blank (or omit) for local development.
VITE_CLERK_PROXY_URL=
